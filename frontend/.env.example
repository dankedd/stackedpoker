# ── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
# IMPORTANT: Use ONLY the base project URL — no /rest/v1/ suffix.
# Correct:   https://xxxxxxxxxxxx.supabase.co
# Wrong:     https://xxxxxxxxxxxx.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ──────────────────────────────────────────────────────────────
# Local dev:     http://localhost:8000
# Production:    https://stackedpoker-production.up.railway.app
# IMPORTANT: Set this on Vercel → Settings → Environment Variables
# The Next.js rewrite proxy uses this to route /api/* to the backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Canonical site URL ────────────────────────────────────────────────────────
# The ONE production hostname for the whole app. Used to build OAuth and
# email-confirmation redirect URLs (see lib/site-url.ts) so they never leak
# the *.vercel.app deployment URL. Leave unset for local dev.
# Production (set on Vercel → Settings → Environment Variables):
# NEXT_PUBLIC_SITE_URL=https://stackedpokerai.com
