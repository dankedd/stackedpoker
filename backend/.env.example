# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/stacked_poker

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# ── Supabase ──────────────────────────────────────────────
# Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Dashboard → Project Settings → API → service_role key (NEVER expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Server ────────────────────────────────────────────────
DEBUG=false
# Local dev:  http://localhost:3000
# Production: https://stackedpokerai.com  (the ONLY canonical prod domain —
# never the *.vercel.app deployment URL)
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend origin (Stripe redirects) ─────────────────────
# Server-configured origin used to build Stripe Checkout success/cancel URLs
# and Billing Portal return URLs — never taken from client-supplied values.
# Local dev:  http://localhost:3000
# Production: https://stackedpokerai.com  (set this on Railway — if it's
# stale/missing, Stripe checkout/portal sends users back to whatever this
# was last set to, e.g. an old *.vercel.app URL)
FRONTEND_URL=http://localhost:3000
